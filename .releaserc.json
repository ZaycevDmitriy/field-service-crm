{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    ["@semantic-release/commit-analyzer", { "preset": "conventionalcommits" }],
    ["@semantic-release/release-notes-generator", { "preset": "conventionalcommits" }],
    ["@semantic-release/changelog", { "changelogFile": "CHANGELOG.md", "changelogTitle": "# Changelog" }],
    ["@semantic-release/exec", { "prepareCmd": "bash scripts/release/build-android.sh ${nextRelease.version}" }],
    ["@semantic-release/git", {
      "assets": ["CHANGELOG.md"],
      "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
    }],
    ["@semantic-release/github", {
      "assets": [
        { "path": "dist/*.fingerprint.txt", "label": "runtimeVersion fingerprint" }
      ]
    }],
    ["@semantic-release/exec", { "publishCmd": "bash scripts/release/publish-delivery.sh ${nextRelease.version}" }]
  ]
}
